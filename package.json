{
  "name": "orkajs-monorepo",
  "private": true,
  "description": "OrkaJS - TypeScript framework for building production-ready LLM systems.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orka-ai/orkajs.git"
  },
  "homepage": "https://orkajs.com",
  "bugs": {
    "url": "https://github.com/orka-ai/orkajs/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "author": "Orka Team",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "tsup": "^8.0.1",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "path-to-regexp": ">=0.1.13",
      "picomatch": ">=4.0.4",
      "esbuild": ">=0.25.0",
      "vite": ">=6.4.2"
    }
  }
}
