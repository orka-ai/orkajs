{
  "name": "@orka-js/realtime",
  "version": "1.5.1",
  "description": "Voice agent for OrkaJS — STT → LLM → TTS pipeline with WebSocket support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@orka-js/core": "workspace:*",
    "@orka-js/agent": "workspace:*"
  },
  "peerDependencies": {
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "orkajs",
    "orka",
    "realtime",
    "voice",
    "stt",
    "tts",
    "whisper",
    "speech",
    "streaming",
    "llm",
    "ai",
    "typescript"
  ]
}
