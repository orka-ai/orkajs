{
  "name": "@orka-js/cli",
  "version": "1.5.1",
  "description": "CLI for OrkaJS — npx orka init, orka dev",
  "type": "module",
  "bin": {
    "orka": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "orkajs",
    "orka",
    "cli",
    "command-line",
    "scaffold",
    "typescript",
    "ai"
  ]
}
