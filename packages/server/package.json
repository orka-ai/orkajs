{
  "name": "@orka-js/server",
  "version": "1.5.1",
  "description": "Dev server with React+Vite playground for OrkaJS agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts && tsup",
    "build:ui": "vite build --config vite.config.ts",
    "build:server": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@orka-js/core": "workspace:*",
    "@orka-js/agent": "workspace:*",
    "express": "^4.21.2",
    "ws": "^8.16.0",
    "serve-static": "^1.15.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/serve-static": "^1.15.5",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "vite": "^6.4.2",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "orkajs",
    "orka",
    "server",
    "http",
    "rest",
    "api",
    "agent",
    "sse",
    "streaming",
    "llm",
    "ai",
    "typescript"
  ]
}
