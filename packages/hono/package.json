{
  "name": "@orka-js/hono",
  "version": "1.0.2",
  "description": "Hono middleware for OrkaJS agents — edge-compatible AI agent HTTP endpoints",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "orkajs",
    "orka",
    "hono",
    "edge",
    "cloudflare",
    "middleware",
    "ai",
    "agent",
    "sse"
  ],
  "author": "OrkaJS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orka-js/orkajs.git",
    "directory": "packages/hono"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@orka-js/core": "workspace:*",
    "@orka-js/agent": "workspace:*"
  },
  "devDependencies": {
    "hono": "^4.12.12",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "hono": ">=4.12.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
