{
  "name": "@orka-js/google",
  "version": "1.0.3",
  "description": "Google AI (Gemini) adapter for OrkaJS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@orka-js/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "orka",
    "ai",
    "llm",
    "google",
    "gemini",
    "adapter"
  ],
  "author": "Orka AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orka-ai/orkajs.git",
    "directory": "packages/google"
  },
  "publishConfig": {
    "access": "public"
  }
}
