{
  "name": "@orka-js/mcp",
  "version": "1.1.2",
  "description": "Model Context Protocol (MCP) client, server, and gateway for OrkaJS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./gateway": {
      "import": {
        "types": "./dist/gateway.d.ts",
        "default": "./dist/gateway.js"
      },
      "require": {
        "types": "./dist/gateway.d.cts",
        "default": "./dist/gateway.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@orka-js/core": "^1.5.0"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "keywords": [
    "orka",
    "orkajs",
    "mcp",
    "model-context-protocol",
    "llm",
    "ai",
    "agents",
    "tools"
  ],
  "author": "OrkaJS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orka-js/orkajs.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/orka-js/orkajs/issues"
  },
  "homepage": "https://orkajs.com/en/mcp"
}
