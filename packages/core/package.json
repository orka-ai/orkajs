{
  "name": "@orka-js/core",
  "version": "1.5.0",
  "description": "Core types, interfaces and classes for OrkaJS - TypeScript LLM framework",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "orkajs",
    "llm",
    "ai",
    "typescript",
    "core"
  ],
  "author": "Orka Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orka-ai/orkajs.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
