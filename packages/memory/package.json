{
  "name": "@orkajs/memory",
  "version": "0.1.0",
  "description": "In-memory vector store adapter for OrkaJS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "orkajs",
    "vectordb",
    "memory",
    "in-memory"
  ],
  "author": "Orka Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orka-ai/orkajs.git",
    "directory": "packages/memory"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@orkajs/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
