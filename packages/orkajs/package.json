{
  "name": "orkajs",
  "version": "3.6.7",
  "description": "OrkaJS - TypeScript framework for building production-ready LLM systems",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "orkajs",
    "llm",
    "ai",
    "typescript",
    "openai",
    "anthropic",
    "rag",
    "agent",
    "framework",
    "gpt3",
    "chain",
    "prompt",
    "prompt engineering",
    "chatgpt",
    "machine learning",
    "openai",
    "embeddings",
    "vectorstores"
  ],
  "author": "Orka Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orka-ai/orkajs.git",
    "directory": "packages/orkajs"
  },
  "homepage": "https://orkajs.com",
  "bugs": {
    "url": "https://github.com/orka-ai/orkajs/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@orka-js/core": "^1.5.0",
    "@orka-js/openai": "^1.3.0",
    "@orka-js/anthropic": "^1.2.0",
    "@orka-js/mistral": "^1.1.5",
    "@orka-js/ollama": "^1.1.5",
    "@orka-js/memory": "^1.0.7",
    "@orka-js/pinecone": "^1.0.7",
    "@orka-js/qdrant": "^1.0.7",
    "@orka-js/chroma": "^1.0.7",
    "@orka-js/agent": "^1.5.0",
    "@orka-js/tools": "^1.2.6",
    "@orka-js/cache": "^1.0.8",
    "@orka-js/resilience": "^1.0.7",
    "@orka-js/orchestration": "^1.1.0",
    "@orka-js/workflow": "^1.0.8",
    "@orka-js/graph": "^1.4.0",
    "@orka-js/evaluation": "^1.1.0",
    "@orka-js/observability": "^1.0.8",
    "@orka-js/prompts": "^1.0.7",
    "@orka-js/memory-store": "^1.3.0",
    "@orka-js/ocr": "^1.1.6",
    "@orka-js/devtools": "^1.6.2",
    "@orka-js/mcp": "^1.1.2",
    "@orka-js/finetuning": "^1.1.2",
    "@orka-js/test": "workspace:*",
    "@orka-js/durable": "workspace:*",
    "@orka-js/express": "workspace:*",
    "@orka-js/hono": "workspace:*",
    "@orka-js/realtime": "workspace:*",
    "@orka-js/server": "workspace:*",
    "@orka-js/a2a": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
