{
  "name": "@orka-js/durable",
  "version": "1.0.0",
  "description": "Durable, resumable, and scheduled agents for OrkaJS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "orkajs",
    "orka",
    "durable",
    "agent",
    "persistent",
    "scheduler",
    "llm",
    "ai"
  ],
  "author": "OrkaJS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orka-js/orkajs.git",
    "directory": "packages/durable"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@orka-js/agent": "workspace:*",
    "@orka-js/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "node-cron": "^3.0.0",
    "redis": "^4.6.0"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    },
    "node-cron": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
