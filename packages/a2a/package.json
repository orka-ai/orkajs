{
  "name": "@orka-js/a2a",
  "version": "1.5.2",
  "description": "Google A2A (Agent-to-Agent) protocol implementation for OrkaJS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@orka-js/core": "workspace:*",
    "@orka-js/agent": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4.21.2"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "orkajs",
    "orka",
    "a2a",
    "agent-to-agent",
    "multi-agent",
    "protocol",
    "llm",
    "ai",
    "typescript"
  ]
}
