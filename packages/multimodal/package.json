{
  "name": "@orka-js/multimodal",
  "version": "3.0.0",
  "description": "Multimodal utilities and agents for OrkaJS - Vision, Audio, Cross-modal workflows",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "orkajs",
    "multimodal",
    "vision",
    "audio",
    "whisper",
    "tts",
    "gpt-4v",
    "claude-vision",
    "llm",
    "ai"
  ],
  "author": "OrkaJS Team",
  "license": "MIT",
  "dependencies": {
    "@orka-js/core": "^1.5.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@orka-js/openai": "^1.3.0",
    "@orka-js/anthropic": "^1.2.0"
  },
  "peerDependenciesMeta": {
    "@orka-js/openai": {
      "optional": true
    },
    "@orka-js/anthropic": {
      "optional": true
    }
  }
}
