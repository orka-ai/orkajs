{
  "name": "@orka-js/react",
  "version": "1.5.0",
  "description": "React component for visualizing OrkaJS graph workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@orka-js/core": "workspace:*",
    "@orka-js/graph": "workspace:*",
    "@xyflow/react": "^12.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "orkajs",
    "orka",
    "react",
    "visualization",
    "graph",
    "workflow",
    "ui",
    "components",
    "typescript"
  ]
}
