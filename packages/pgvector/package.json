{
  "name": "@orka-js/pgvector",
  "version": "0.1.0",
  "description": "pgvector adapter for OrkaJS — works with PostgreSQL and Supabase",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "orkajs",
    "vectordb",
    "pgvector",
    "postgres",
    "supabase"
  ],
  "author": "Orka Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orka-ai/orkajs.git",
    "directory": "packages/pgvector"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@orka-js/core": "^1.3.3"
  },
  "peerDependencies": {
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
