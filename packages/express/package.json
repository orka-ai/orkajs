{
  "name": "@orka-js/express",
  "version": "1.0.1",
  "description": "Express.js middleware for OrkaJS agents — expose agents as HTTP endpoints with SSE streaming",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "orkajs",
    "orka",
    "express",
    "middleware",
    "ai",
    "agent",
    "http",
    "sse",
    "streaming"
  ],
  "author": "OrkaJS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orka-js/orkajs.git",
    "directory": "packages/express"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@orka-js/core": "workspace:*",
    "@orka-js/agent": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "express": "^4.18.3",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
