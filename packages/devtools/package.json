{
  "name": "@orka-js/devtools",
  "version": "1.1.0",
  "description": "Visual debugging and observability dashboard for OrkaJS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "ui"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@orka-js/core": "workspace:*",
    "@orka-js/observability": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "keywords": [
    "orkajs",
    "devtools",
    "llm",
    "observability",
    "tracing",
    "debugging"
  ],
  "author": "OrkaJS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orka-ai/orkajs.git",
    "directory": "packages/devtools"
  }
}
